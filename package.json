{
  "name": "ko-works-website",
  "version": "1.0.0",
  "private": true,
  "description": "KO WORKS LLC marketing site",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./dist/tailwind.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ./dist/tailwind.css --watch",
    "serve": "python3 -m http.server 8080",
    "dev": "concurrently -n css,server -c cyan,magenta --kill-others-on-fail \"npm run watch\" \"npm run serve\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "tailwindcss": "^3.4.19"
  }
}
